# Google OAuth 2.0 Configuration for Gmail Smart Cleaner
# -------------------------------------------------------------
# 你需要从 Google Cloud Console 下载 OAuth 2.0 凭证，并在下方填入对应的信息。
# 或者，直接将 credentials.json 命名为 google_credentials.json 并放入 backend 目录中。

# FastAPI Session Secret Key (用于加密 Cookie)
SESSION_SECRET_KEY=super-secret-random-key-change-in-production

# Front-end Redirect URL
FRONTEND_URL=http://localhost:5173

# Google OAuth 2.0 Credentials (若要通过环境变量单独指定)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Gemini API Key (用于智能清洗 Agent)
GEMINI_API_KEY=

#通过验证
OAUTHLIB_INSECURE_TRANSPORT=1
